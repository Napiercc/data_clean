{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FacebookThreadAnnotationV4ThreeFields",
  "type": "object",
  "properties": {
    "topic_relevance": {
      "type": "string",
      "enum": ["strongly_relevant", "relevant", "off_topic"]
    },
    "training_grade": {
      "type": "string",
      "enum": [
        "core_usable",
        "generally_usable",
        "borderline_sample",
        "relevant_context_only",
        "unusable"
      ]
    },
    "annotation_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400
    }
  },
  "required": [
    "topic_relevance",
    "training_grade",
    "annotation_reason"
  ],
  "additionalProperties": false
}
